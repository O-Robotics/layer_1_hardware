<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <joint name="gnss_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gnss_link"/>
    <origin xyz="0 0 0.199" rpy="0 0 0"/>
  </joint>

  <link name="gnss_link">
    <visual>
      <origin xyz="0.0 0 -0.199" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/GNSS.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

</robot>
