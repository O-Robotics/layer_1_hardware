<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_footprint"/>

  <link name="base_roll_link"/>

  <joint name="base_roll_joint" type="revolute">
    <parent link="base_footprint"/>
    <child link="base_roll_link"/>
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.141592653589793" upper="3.141592653589793" effort="1.0" velocity="10.0"/>
  </joint>

  <link name="base_pitch_link"/>

  <joint name="base_pitch_joint" type="revolute">
    <parent link="base_roll_link"/>
    <child link="base_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.141592653589793" upper="3.141592653589793" effort="1.0" velocity="10.0"/>
  </joint>

  <joint name="base_link_mount_joint" type="fixed">
    <parent link="base_pitch_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/Chassis.stl"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <origin xyz="0.064266 0.001648 0.095511" rpy="0 0 0"/>
      <mass value="20.656"/>
      <inertia ixx="0.110436033" ixy="0.007458962" ixz="-0.047319713" iyy="0.439622462" iyz="0.006320743" izz="0.625226807"/>
    </inertial>
  </link>

  <joint name="LeftWheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.245 0" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/WheelAssembly.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/WheelAssembly.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.000056 0" rpy="0 0 0"/>
      <mass value="0.55"/>
      <inertia ixx="0.000011339" ixy="0" ixz="0" iyy="0.000011339" iyz="0" izz="0.00000758"/>
    </inertial>
  </link>

  <joint name="RightWheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.245 0" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/WheelAssembly.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/WheelAssembly.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.000056 0" rpy="0 0 0"/>
      <mass value="0.55"/>
      <inertia ixx="0.000011339" ixy="0" ixz="0" iyy="0.000011339" iyz="0" izz="0.00000758"/>
    </inertial>
  </link>

  <joint name="tool_joint" type="fixed">
    <origin xyz="0.35 0 0.075" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="tool_link"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="tool_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/Tool.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <origin xyz="0.000083 0.000133 -0.013506" rpy="0 0 0"/>
      <mass value="4.435"/>
      <inertia ixx="0.039857666" ixy="-0.000001082" ixz="0.000003497" iyy="0.003281046" iyz="0.00000967" izz="0.042814946"/>
    </inertial>
  </link>

  <joint name="LeftBrush_joint" type="continuous">
    <origin xyz="0 0.155 -0.08" rpy="0 0 0"/>
    <parent link="tool_link"/>
    <child link="left_brush_link"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.02" friction="0.02"/>
  </joint>

  <link name="left_brush_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/Brush.stl"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/Brush.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.000007 0 -0.00877" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.00677874" ixy="-0.000000018" ixz="-0.000000093" iyy="0.006779851" iyz="0" izz="0.013420097"/>
    </inertial>
  </link>

  <joint name="RightBrush_joint" type="continuous">
    <origin xyz="0 -0.155 -0.08" rpy="0 0 0"/>
    <parent link="tool_link"/>
    <child link="right_brush_link"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.02" friction="0.02"/>
  </joint>

  <link name="right_brush_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/Brush.stl"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://amr_sweeper_description/meshes/Brush.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.000007 0 -0.00877" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.00677874" ixy="-0.000000018" ixz="-0.000000093" iyy="0.006779851" iyz="0" izz="0.013420097"/>
    </inertial>
  </link>

</robot>
