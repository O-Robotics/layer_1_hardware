#!/usr/bin/env bash
set -euo pipefail

workspace_root="@vendor_root@/ros2_vendor_ws"
src_root="${workspace_root}/src"
build_root="@vendor_build@/ros_vendor_colcon_build"
install_root="@vendor_install@"

realsense_repo="${src_root}/realsense-ros"
depth_scan_repo="${src_root}/depthimage_to_laserscan"

clone_or_update() {
  local repo_url="$1"
  local git_ref="$2"
  local target_dir="$3"

  mkdir -p "$(dirname "${target_dir}")"
  if [ ! -d "${target_dir}/.git" ]; then
    git clone --branch "${git_ref}" --depth 1 "${repo_url}" "${target_dir}"
    return
  fi

  git -C "${target_dir}" fetch --depth 1 origin "${git_ref}"
  git -C "${target_dir}" checkout -f FETCH_HEAD
}

clone_or_update "@REALSENSE_ROS_GIT_REPOSITORY@" "@REALSENSE_ROS_GIT_TAG@" "${realsense_repo}"
clone_or_update "@DEPTHIMAGE_TO_LASERSCAN_GIT_REPOSITORY@" "@DEPTHIMAGE_TO_LASERSCAN_GIT_TAG@" "${depth_scan_repo}"

mkdir -p "${workspace_root}" "${build_root}" "${install_root}"

colcon build \
  --merge-install \
  --build-base "${build_root}" \
  --install-base "${install_root}" \
  --base-paths \
    "${realsense_repo}/realsense2_camera_msgs" \
    "${realsense_repo}/realsense2_description" \
    "${realsense_repo}/realsense2_camera" \
    "${depth_scan_repo}" \
  --cmake-args \
    -DCMAKE_BUILD_TYPE=Release \
    "-DCMAKE_PREFIX_PATH=${install_root}:${CMAKE_PREFIX_PATH:-}" \
    "-DAMENT_PREFIX_PATH=${install_root}:${AMENT_PREFIX_PATH:-}"
